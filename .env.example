# Variables d'environnement pour l'agent ADK - Vertex AI
# Copier ce fichier en .env et l'adapter si nécessaire.
# Les Application Default Credentials sont gérées par gcloud, pas ici.

# --- Vertex AI ---
# Active le backend Vertex AI (obligatoire, ne pas modifier)
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ID du projet GCP cible
GOOGLE_CLOUD_PROJECT=acn-researchplatform

# Région Vertex AI (changer si nécessaire : europe-west1, us-central1, etc.)
GOOGLE_CLOUD_LOCATION=us-central1

# --- ADK (optionnel) ---
# Niveau de log : DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
